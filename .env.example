# UrbanKaoberg Dashboard Environment Variables

# Backend Server
PORT=3000

# API Keys (Optional - Dashboard will use mock data if not provided)

# FRED API Key for economic data
FRED_API_KEY=your_fred_api_key_here

# Nasdaq API Key for COT data
NASDAQ_API_KEY=your_nasdaq_api_key_here

# CoinGlass API Key for ETF flows
COINGLASS_API_KEY=your_coinglass_api_key_here

# Frontend Vite Variables
VITE_FRED_API_KEY=your_fred_api_key_here
